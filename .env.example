NEBIUS_API_KEY=XXX

# Optional: point at a running MLflow server. If unset, mlflow falls back to
# its own local default (a sqlite db at ./mlflow.db for tracking metadata,
# artifacts under ./mlruns/) relative to the project root.
# MLFLOW_TRACKING_URI=http://localhost:5000
# MLFLOW_EXPERIMENT_NAME=swe-bench-agent-eval

# Phase 3: S3-compatible upload of runs/<run_id>/ (see pipeline/upload.py).
# Defaults below match the local `minio` service in docker-compose.yaml, so the
# upload step works out of the box in dev. Point S3_ENDPOINT_URL at a real
# provider (Nebius Object Storage, AWS S3, ...) and swap the credentials to
# upload to a real bucket instead.
S3_BUCKET=mlops-assignment-runs
S3_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1

# Phase 3: only needed for `docker compose up` (see docker-compose.yaml).
# Absolute path to this checkout as the *host* Docker daemon sees it - the DAG's
# DockerOperator tasks are launched as sibling containers via the mounted
# /var/run/docker.sock, so this can't be `/opt/airflow` (the scheduler container's own
# view of the repo). On Linux/WSL2: `pwd` from the repo root.
HOST_PROJECT_ROOT=/absolute/path/to/mlops-assignment-e2e-ml-pipeline
# GID of the host's `docker` group, so the airflow containers can use the mounted
# socket: `getent group docker | cut -d: -f3`. Not needed on Docker Desktop.
DOCKER_GID=999
